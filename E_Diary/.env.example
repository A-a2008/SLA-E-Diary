# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# Groq AI (for Telegram bot diary entry processing)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Django (optional)
DJANGO_SECRET_KEY=your_secret_key_here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# On PythonAnywhere: set to False so messages queue in DB instead of sending directly
SEND_MESSAGES_DIRECTLY=False

# Shared secret for Pi bot ↔ PythonAnywhere API auth
API_TOKEN=your_shared_secret_token_here

# Pi bot only: PythonAnywhere base URL
API_BASE_URL=https://slaediary.pythonanywhere.com
